generator client {
  provider     = "prisma-client-js"
  output       = "../src/generated/prisma/client"
  moduleFormat = "esm"
}

datasource db {
  provider = "sqlite"
}

model JournalEntry {
  id              Int           @id @default(autoincrement())
  date            String
  timeOfDay       String?
  content         String
  mood            String?
  moodScore       Int?
  summary         String?
  themes          String        @default("[]")
  sessionComplete Boolean       @default(false)
  createdAt       DateTime      @default(now())
  messages        ChatMessage[]

  @@map("journal_entries")
}

model ChatMessage {
  id        Int          @id @default(autoincrement())
  entryId   Int
  role      String
  content   String
  order     Int          @default(0)
  createdAt DateTime     @default(now())
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@map("chat_messages")
}

model UserProfile {
  id                 Int       @id @default(autoincrement())
  summary            String?
  recurringThemes    String    @default("[]")
  behavioralPatterns String    @default("[]")
  moodTrends         String    @default("[]")
  goalsMentioned     String    @default("[]")
  peopleMentioned    String    @default("[]")
  advice             String    @default("[]")
  entriesAnalyzed    Int       @default(0)
  lastUpdatedAt      DateTime?

  @@map("user_profiles")
}

model Album {
  id                Int                  @id @default(autoincrement())
  batchId           Int?
  title             String
  artist            String
  year              Int?
  genre             String?
  artworkUrl        String?
  itunesId          String?
  status            String               @default("recommended")
  rating            Int?
  notes             String?
  recommendedReason String?
  listenedAt        DateTime?
  createdAt         DateTime             @default(now())
  batch             RecommendationBatch? @relation(fields: [batchId], references: [id])

  @@map("albums")
}

model TasteProfile {
  id               Int       @id @default(autoincrement())
  summary          String?
  favoriteGenres   String    @default("[]")
  favoriteArtists  String    @default("[]")
  preferredDecades String    @default("[]")
  moodPreferences  String    @default("[]")
  dislikedPatterns String    @default("[]")
  albumsAnalyzed   Int       @default(0)
  isUpdating       Boolean   @default(false)
  lastUpdatedAt    DateTime?
  createdAt        DateTime  @default(now())

  @@map("taste_profiles")
}

model RecommendationBatch {
  id        Int                 @id @default(autoincrement())
  prompt    String?
  createdAt DateTime            @default(now())
  albums    Album[]
  logs      RecommendationLog[]

  @@map("recommendation_batches")
}

model StockHolding {
  id       Int      @id @default(autoincrement())
  ticker   String   @unique
  shares   Float
  avgPrice Float
  addedAt  DateTime @default(now())

  @@map("stock_holdings")
}

model AppSettings {
  key   String @id
  value String

  @@map("app_settings")
}

model RecommendationLog {
  id        Int                 @id @default(autoincrement())
  batchId   Int
  level     String
  event     String
  detail    String              @default("{}")
  createdAt DateTime            @default(now())
  batch     RecommendationBatch @relation(fields: [batchId], references: [id])

  @@map("recommendation_logs")
}
